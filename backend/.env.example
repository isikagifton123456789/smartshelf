PORT=5000
FRONTEND_ORIGIN=http://localhost:8080

# Firebase web API key (for Identity Toolkit sign-in/sign-up)
FIREBASE_WEB_API_KEY=your_firebase_web_api_key

# Firebase Admin setup (choose one strategy)
# 1) GOOGLE_APPLICATION_CREDENTIALS=G:/absolute/path/to/service-account.json
# 2) FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# 3) FIREBASE_PROJECT_ID + FIREBASE_CLIENT_EMAIL + FIREBASE_PRIVATE_KEY
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=your_service_account_client_email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# SMTP settings for verification and reset emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM="SmartShelf <your_gmail@gmail.com>"

# Where Firebase email actions redirect after verify/reset
EMAIL_ACTION_CONTINUE_URL=http://localhost:8080/login
